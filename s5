echo "Answer three questions to generate your manifesto."

read -p "1. Name one open-source tool you use daily: " TOOL
read -p "2. In one word, what does freedom mean to you? " FREEDOM
read -p "3. Name one thing you would build and share: " BUILD

DATE=$(date '+%d %B %Y')
OUTPUT="manifesto_arka.txt"

echo "Open Source Manifesto" > $OUTPUT
echo "Date: $DATE" >> $OUTPUT
echo "" >> $OUTPUT
echo "I use $TOOL every day. To me, freedom means $FREEDOM." >> $OUTPUT
echo "In the future, I would love to build $BUILD and share it freely with the world." >> $OUTPUT
echo "Open source allows collaboration, innovation, and knowledge sharing." >> $OUTPUT

echo ""
echo "Manifesto saved to $OUTPUT"
cat $OUTPUT